# Supabase Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Required for mobile app (Android via BuildConfig, iOS via Config.xcconfig)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Required for Google Maps SDK map rendering (Android manifest + iOS Info.plist)
# Note: This key is ONLY for the Maps SDK (map rendering). The Places API
# is now handled server-side via the google-places Supabase Edge Function.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# Server-side only (Supabase Edge Functions)
# ============================================
# These keys should be set as Supabase secrets, NOT in this file.
#
# Gemini API key (used by analyze-dish Edge Function):
#   supabase secrets set GEMINI_API_KEY=your-gemini-api-key
#
# Google Places API key (used by google-places Edge Function):
#   supabase secrets set GOOGLE_PLACES_API_KEY=your-google-places-api-key
