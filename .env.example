# Supabase Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Required for mobile app
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Required for Google Maps (Android only)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# Server-side only (Supabase Edge Functions)
# ============================================
# GEMINI_API_KEY should be set as a secret in Supabase, NOT in this file
# Run: supabase secrets set GEMINI_API_KEY=your-gemini-api-key
