# ═══════════════════════════════════════════════════════════════════
# SmackCheck - Supabase Edge Functions Environment Variables
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
# ═══════════════════════════════════════════════════════════════════

# Expo Access Token (for enhanced push notification security)
# Generate at: https://expo.dev/accounts/_/settings/access-tokens
EXPO_ACCESS_TOKEN=your-expo-access-token-here

# Firebase Cloud Messaging (FCM) - Required for Android push notifications
# Get from Firebase Console > Project Settings > General
FIREBASE_PROJECT_ID=your-firebase-project-id-here

# Firebase Service Account JSON (for server-to-server FCM auth)
# Generate at: Firebase Console > Project Settings > Service accounts > Generate new private key
# Paste the entire JSON contents as a single line
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
