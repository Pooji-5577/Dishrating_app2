<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<!-- Privacy usage descriptions — required or iOS will crash on permission request -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>SmackCheck uses your location to find nearby restaurants and detect when you visit them.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>SmackCheck uses your location in the background to automatically detect restaurant visits.</string>
	<key>NSCameraUsageDescription</key>
	<string>SmackCheck uses your camera to photograph dishes for rating.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>SmackCheck accesses your photo library to upload dish photos.</string>

	<!-- Google Maps SDK API Key for iOS map rendering -->
	<!-- For production, use $(GOOGLE_MAPS_API_KEY) from .xcconfig instead of hardcoding -->
	<key>GOOGLE_MAPS_API_KEY</key>
	<string>$(GOOGLE_MAPS_API_KEY)</string>

	<!-- Supabase configuration — read by SupabaseConfig.ios.kt at runtime -->
	<!-- For production, use $(SUPABASE_URL) and $(SUPABASE_ANON_KEY) from .xcconfig -->
	<key>SUPABASE_URL</key>
	<string>$(SUPABASE_URL)</string>
	<key>SUPABASE_ANON_KEY</key>
	<string>$(SUPABASE_ANON_KEY)</string>

	<!-- Force light mode until internal dark mode is introduced -->
	<key>UIUserInterfaceStyle</key>
	<string>Light</string>

	<!-- OAuth redirect URL scheme for Supabase (Google, Facebook, Apple sign-in) -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>smackcheck</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
